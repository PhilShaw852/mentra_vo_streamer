# Get your API key and set your app package name at console.mentra.glass
MENTRAOS_API_KEY=your_api_key_here
MENTRAOS_PACKAGE_NAME=com.mentra.streamapp

# Optional: port for the app server (default 3010)
PORT=3010

# Edge RTMP receiver (on this device). Glasses stream here; you can watch at /watch.html
RTMP_PORT=19350
RTMP_HTTP_PORT=8010
RTMP_APP=live
RTMP_STREAM_KEY=mentra
