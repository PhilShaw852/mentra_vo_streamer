{
  "name": "mentra-vo-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "LOG_LEVEL=debug bun run src/index.ts",
    "start": "bun run src/index.ts",
    "tunnel": "ngrok http --url=modifiable-presymphysial-alisia.ngrok-free.dev 3010",
    "dev:all": "concurrently \"bun run dev\" \"bun run tunnel\"",
    "detect": ".venv/bin/python detect/detect_stream.py"
  },
  "dependencies": {
    "@mentra/sdk": "latest",
    "express": "^4.21.0",
    "node-media-server": "^4.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
